{
  "theme": "Dark",
  "archetype": "5 (Jewel & Luxury)",
  "color_palette": {
    "background": {
      "primary": "#0A0A0A",
      "surface": "#141414",
      "surface_elevated": "#1C1C1E"
    },
    "brand": {
      "primary": "#D4AF37",
      "secondary": "#F3E5AB",
      "muted": "#8C7326"
    },
    "text": {
      "primary": "#FFFFFF",
      "secondary": "#A1A1AA",
      "inverse": "#0A0A0A"
    },
    "border": {
      "default": "rgba(255, 255, 255, 0.1)",
      "focus": "rgba(212, 175, 55, 0.5)"
    },
    "status": {
      "success": "#27AE60",
      "error": "#E74C3C"
    }
  },
  "typography": {
    "fonts": {
      "heading": "Playfair Display",
      "body": "Manrope"
    },
    "scale": {
      "h1": {
        "fontSize": 32,
        "lineHeight": 40,
        "fontFamily": "Playfair Display",
        "letterSpacing": -0.5
      },
      "h2": {
        "fontSize": 24,
        "lineHeight": 32,
        "fontFamily": "Playfair Display"
      },
      "h3": {
        "fontSize": 20,
        "lineHeight": 28,
        "fontFamily": "Playfair Display"
      },
      "bodyLarge": {
        "fontSize": 18,
        "lineHeight": 26,
        "fontFamily": "Manrope"
      },
      "body": {
        "fontSize": 16,
        "lineHeight": 24,
        "fontFamily": "Manrope"
      },
      "caption": {
        "fontSize": 12,
        "lineHeight": 16,
        "fontFamily": "Manrope",
        "textTransform": "uppercase",
        "letterSpacing": 1.2
      }
    }
  },
  "spacing": {
    "xs": 4,
    "sm": 8,
    "md": 16,
    "lg": 24,
    "xl": 32,
    "2xl": 48
  },
  "components": {
    "button": {
      "primary": {
        "backgroundColor": "#D4AF37",
        "borderRadius": 0,
        "paddingVertical": 16,
        "paddingHorizontal": 24,
        "alignItems": "center"
      },
      "secondary": {
        "backgroundColor": "transparent",
        "borderWidth": 1,
        "borderColor": "#D4AF37",
        "borderRadius": 0,
        "paddingVertical": 16,
        "paddingHorizontal": 24,
        "alignItems": "center"
      }
    },
    "card": {
      "backgroundColor": "#141414",
      "borderWidth": 1,
      "borderColor": "rgba(255, 255, 255, 0.05)",
      "borderRadius": 4,
      "padding": 24
    },
    "input": {
      "backgroundColor": "#0A0A0A",
      "borderWidth": 1,
      "borderColor": "rgba(255, 255, 255, 0.1)",
      "borderRadius": 4,
      "padding": 16,
      "color": "#FFFFFF"
    },
    "bottom_tab": {
      "backgroundColor": "#0A0A0A",
      "activeTintColor": "#D4AF37",
      "inactiveTintColor": "#A1A1AA",
      "borderTopWidth": 1,
      "borderTopColor": "rgba(255, 255, 255, 0.05)"
    }
  },
  "layouts": {
    "user_app": {
      "navigation": [
        "Home",
        "Bookings",
        "Profile"
      ],
      "home_structure": [
        "Hero Promo Banner",
        "Categories Grid (Hair, Spa, Nails, Facial)",
        "Top Professionals List (Horizontal Scroll)"
      ],
      "booking_flow": [
        "Select Service",
        "Select Professional",
        "Date & Time Picker",
        "Apply Promo",
        "Mock Payment"
      ]
    },
    "admin_app": {
      "navigation": [
        "Dashboard",
        "Bookings",
        "Professionals",
        "Services"
      ],
      "dashboard_structure": [
        "Today's Revenue Widget",
        "Target Achievement Progress",
        "Recent Bookings List"
      ]
    }
  },
